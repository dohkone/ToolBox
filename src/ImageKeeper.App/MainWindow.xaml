<Window x:Class="ImageKeeper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ImageKeeper.App.ViewModels"
        mc:Ignorable="d"
        Title="TEMU 工具箱"
        Icon="pack://application:,,,/Assets/new_logo.png"
        Width="1660"
        Height="960"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#C7D2E6"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border x:Name="VerticalRoot"
                                    Margin="0,2,0,2"
                                    Background="#EEF2F8"
                                    CornerRadius="3">
                                <Track Name="PART_Track"
                                       IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageUpCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageDownCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>

                            <Border x:Name="HorizontalRoot"
                                    Margin="2,0,2,0"
                                    Background="#EEF2F8"
                                    CornerRadius="3"
                                    Visibility="Collapsed">
                                <Track Orientation="Horizontal">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageLeftCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageRightCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="VerticalRoot" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="HorizontalRoot" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Padding" Value="8,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#303133" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#1F2A37" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D6DCE8" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D6DCE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ElementInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#DCDFE6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MultiLineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="ElementSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCDFE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ElementPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#409EFF" />
            <Setter Property="BorderBrush" Value="#409EFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

        <Grid>
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="12,16,0,16"
              Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Button Command="{Binding ShowImageGenerateCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImageGenerateSelected}" Value="True">
                                    <Setter Property="Background" Value="#EEEEEE" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="AI&#29983;&#22270;" />
                </Button>

                <Button Command="{Binding ShowReviewWorkspaceCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReviewWorkspaceSelected}" Value="True">
                                    <Setter Property="Background" Value="#EEEEEE" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#22270;&#29255;&#22788;&#29702;" />
                </Button>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Margin="12,0,0,0"
                       HorizontalAlignment="Left"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="11"
                       Text="ToolBox" />
        </Grid>

        <Grid Grid.Column="1"
              Margin="12,12,12,12">
            <Grid Visibility="{Binding IsReviewWorkspaceSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="352" />
                </Grid.ColumnDefinitions>

                <Grid Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2" />
                        <ColumnDefinition Width="346" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,10"
                            Padding="0,0,0,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                        <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Horizontal">
                                <ItemsControl ItemsSource="{Binding WorkspaceTabs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:WorkspaceTabViewModel}">
                                            <Border Margin="0,0,8,0"
                                                    MinWidth="168"
                                                    Height="36">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFFFFF" />
                                                        <Setter Property="BorderBrush" Value="#C8D7F4" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="CornerRadius" Value="8,8,0,0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="White" />
                                                                <Setter Property="BorderBrush" Value="#2D6AE3" />
                                                                <Setter Property="Margin" Value="0,0,8,-1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Padding="10,6,4,6"
                                                            HorizontalContentAlignment="Left"
                                                            VerticalContentAlignment="Center"
                                                            Style="{StaticResource FlatButtonStyle}"
                                                            Command="{Binding ActivateCommand}">
                                                        <TextBlock Width="120"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Text="{Binding Title}" />
                                                    </Button>
                                                    <Button Grid.Column="1"
                                                            Width="22"
                                                            Height="22"
                                                            Margin="2,0,8,0"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Style="{StaticResource FlatButtonStyle}"
                                                            Foreground="#667085"
                                                            FontSize="12"
                                                            Command="{Binding CloseCommand}"
                                                            Content="×" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Margin="0,0,0,2"
                                        Command="{Binding AddTabCommand}"
                                        Style="{StaticResource SmallIconButtonStyle}"
                                        Content="+" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <WrapPanel Grid.Row="1"
                               Grid.ColumnSpan="3"
                               Margin="0,2,0,8"
                               Orientation="Horizontal">
                        <Button Command="{Binding ChooseFolderCommand}"
                                Margin="0,0,8,0"
                                Content="选择文件夹" />
                        <Button Command="{Binding SelectBackupFolderCommand}"
                                Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="备份位置" />
                    </WrapPanel>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,12"
                            Padding="14,10"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="{Binding LoadedFolderText}" />
                            <TextBlock Margin="0,4,0,4"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding SelectionSummaryText}" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding BackupFolderText}" />

                            <Border Margin="0,10,0,0"
                                    Padding="12,10"
                                    Background="#F7F9FC"
                                    CornerRadius="8"
                                    Visibility="{Binding IsLoadingVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding LoadingTitle}" />
                                    <TextBlock Margin="0,4,0,8"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding LoadingDetail}"
                                               TextWrapping="Wrap" />
                                    <ProgressBar Height="8"
                                                 IsIndeterminate="{Binding IsScanProgressIndeterminate, Mode=OneWay}"
                                                 Maximum="100"
                                                 Value="{Binding ScanProgressValue, Mode=OneWay}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding ScanProgressText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.Column="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Grid>
                            <Grid Visibility="{Binding HasTabs, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="12">
                                    <ItemsControl ItemsSource="{Binding SelectedTab.RootCards}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewModels:RootCardViewModel}">
                                                <Grid Margin="0,0,0,10">
                                                    <Grid Visibility="{Binding IsCollapsed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Border Background="#F0F9EB"
                                                                BorderBrush="#CDE7B0"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="14,12">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Button Grid.Column="0"
                                                                        HorizontalContentAlignment="Left"
                                                                        Style="{StaticResource FlatButtonStyle}"
                                                                        Command="{Binding ExpandCommand}">
                                                                    <TextBlock FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding CollapsedSummaryText}" />
                                                                </Button>
                                                                <StackPanel Grid.Column="1"
                                                                            Orientation="Horizontal">
                                                                    <Button Margin="0,0,8,0"
                                                                            Content="编辑"
                                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                                            Command="{Binding ExpandCommand}" />
                                                                    <Button Content="自动上架"
                                                                            Command="{Binding AutoPublishCommand}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>

                                                    <Border Padding="8"
                                                            Background="#FFFFFF"
                                                            BorderBrush="#D9E1EC"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                        <Grid>
                                                            <Grid Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="190" />
                                                                <ColumnDefinition Width="1" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Grid.Column="0"
                                                                  Margin="0,0,12,0">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>

                                                                <ScrollViewer Grid.Row="0"
                                                                              VerticalScrollBarVisibility="Auto"
                                                                              HorizontalScrollBarVisibility="Disabled"
                                                                              PreviewMouseWheel="NestedScrollViewer_OnPreviewMouseWheel">
                                                                    <ItemsControl ItemsSource="{Binding VisibleNodes}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type viewModels:FolderNodeViewModel}">
                                                                                <Grid Margin="{Binding Indent}">
                                                                                    <Button HorizontalContentAlignment="Stretch"
                                                                                            Style="{StaticResource FlatButtonStyle}"
                                                                                            Command="{Binding DataContext.SelectNodeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                            CommandParameter="{Binding}">
                                                                                        <Border Margin="0,0,0,4"
                                                                                                Padding="10,11"
                                                                                                Background="{Binding RowBackground}"
                                                                                                BorderBrush="{Binding RowBorderBrush}"
                                                                                                BorderThickness="1"
                                                                                                CornerRadius="10">
                                                                                            <Grid>
                                                                                                <Grid.ColumnDefinitions>
                                                                                                    <ColumnDefinition Width="22" />
                                                                                                    <ColumnDefinition Width="*" />
                                                                                                    <ColumnDefinition Width="Auto" />
                                                                                                </Grid.ColumnDefinitions>
                                                                                                <Button Grid.Column="0"
                                                                                                        Width="18"
                                                                                                        Height="18"
                                                                                                        Margin="0,0,8,0"
                                                                                                        HorizontalAlignment="Left"
                                                                                                        VerticalAlignment="Center"
                                                                                                        FontSize="13"
                                                                                                        FontWeight="SemiBold"
                                                                                                        Foreground="#5C6E91"
                                                                                                        Background="Transparent"
                                                                                                        BorderBrush="Transparent"
                                                                                                        Style="{StaticResource FlatButtonStyle}"
                                                                                                        Command="{Binding DataContext.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                                        CommandParameter="{Binding}"
                                                                                                        Content="{Binding ExpandGlyph}" />
                                                                                                <TextBlock Grid.Column="1"
                                                                                                           VerticalAlignment="Center"
                                                                                                           FontSize="13"
                                                                                                           FontWeight="{Binding DisplayWeight}"
                                                                                                           Foreground="{Binding NameForeground}"
                                                                                                           Text="{Binding DisplayName}" />
                                                                                                <TextBlock Grid.Column="2"
                                                                                                           Margin="12,0,0,0"
                                                                                                           VerticalAlignment="Center"
                                                                                                           FontSize="12"
                                                                                                           Foreground="{Binding CountForeground}"
                                                                                                           Text="{Binding ImageCountText}" />
                                                                                            </Grid>
                                                                                        </Border>
                                                                                    </Button>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </ScrollViewer>
                                                            </Grid>

                                                            <Border Grid.Column="1"
                                                                    Margin="0,0,10,0"
                                                                    Background="#E2E8F0" />

                                                            <Grid Grid.Column="2"
                                                                  Background="{Binding ContentBackgroundBrush}"
                                                                  AllowDrop="True"
                                                                  Drop="WorkspaceContentBorder_OnDrop"
                                                                  DragEnter="WorkspaceContentBorder_OnDragEnter"
                                                                  DragOver="WorkspaceContentBorder_OnDragOver"
                                                                  DragLeave="WorkspaceContentBorder_OnDragLeave">
                                                                <Grid Margin="8,6,8,8">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>

                                                                    <DockPanel LastChildFill="False">
                                                                        <StackPanel DockPanel.Dock="Right"
                                                                                    Orientation="Horizontal"
                                                                                    HorizontalAlignment="Right">
                                                                            <Button Margin="0,0,8,8"
                                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                                    Command="{Binding AddImagesCommand}"
                                                                                    Content="添加图片" />
                                                                            <Button Margin="0,0,8,8"
                                                                                    Foreground="{StaticResource DangerBrush}"
                                                                                    Background="{StaticResource DangerSoftBrush}"
                                                                                    BorderBrush="{StaticResource DangerBrush}"
                                                                                    Command="{Binding MoveSelectedCommand}"
                                                                                    Content="移动选中" />
                                                                            <Button Margin="0,0,0,8"
                                                                                    Background="#0F8A43"
                                                                                    BorderBrush="#0F8A43"
                                                                                    Command="{Binding CollapseCommand}"
                                                                                    Content="已修改" />
                                                                        </StackPanel>
                                                                    </DockPanel>

                                                                    <Grid Grid.Row="1"
                                                                          Margin="0,0,0,0">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto" />
                                                                        </Grid.RowDefinitions>

                                                                        <Button HorizontalAlignment="Right"
                                                                                VerticalAlignment="Top"
                                                                                Margin="0,0,0,8"
                                                                                Background="#2563EB"
                                                                                BorderBrush="#2563EB"
                                                                                Command="{Binding LoadMoreImagesCommand}"
                                                                                Content="继续加载"
                                                                                Visibility="{Binding HasMoreImages, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                                        <TextBlock
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                                   Text="{Binding ContentEmptyText}"
                                                                                   TextAlignment="Center"
                                                                                   TextWrapping="Wrap"
                                                                                   Visibility="{Binding HasImages, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                                                                        <ScrollViewer
                                                                                     Margin="0,0,0,0"
                                                                                      VerticalAlignment="Top"
                                                                                      VerticalScrollBarVisibility="Auto"
                                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                                      Visibility="{Binding HasImages, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                      PreviewMouseWheel="NestedScrollViewer_OnPreviewMouseWheel">
                                                                            <ItemsControl ItemsSource="{Binding CurrentImages}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <WrapPanel />
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate DataType="{x:Type viewModels:ImageItemViewModel}">
                                                                                        <Border Width="116"
                                                                                                Margin="0,0,8,8"
                                                                                                Padding="8"
                                                                                                Background="{Binding CardBackground}"
                                                                                                BorderBrush="{Binding CardBorderBrush}"
                                                                                                BorderThickness="1"
                                                                                                CornerRadius="8">
                                                                                            <Border.ContextMenu>
                                                                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                                                                    <MenuItem Header="打开图片"
                                                                                                              Command="{Binding OpenFileCommand}" />
                                                                                                    <MenuItem Header="打开图片所在文件夹"
                                                                                                              Command="{Binding OpenContainingFolderCommand}" />
                                                                                                    <Separator />
                                                                                                    <MenuItem Header="复制图片路径"
                                                                                                              Command="{Binding CopyPathCommand}" />
                                                                                                </ContextMenu>
                                                                                            </Border.ContextMenu>
                                                                                            <Grid>
                                                                                                <Grid.RowDefinitions>
                                                                                                    <RowDefinition Height="Auto" />
                                                                                                    <RowDefinition Height="Auto" />
                                                                                                </Grid.RowDefinitions>

                                                                                                <CheckBox HorizontalAlignment="Right"
                                                                                                          VerticalAlignment="Top"
                                                                                                          Margin="0,-2,0,0"
                                                                                                          Content="选中"
                                                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                                                                                <StackPanel Grid.Row="1">
                                                                                                    <Button Margin="0,8,0,0"
                                                                                                            Padding="0"
                                                                                                            HorizontalContentAlignment="Stretch"
                                                                                                            VerticalContentAlignment="Stretch"
                                                                                                            Style="{StaticResource FlatButtonStyle}"
                                                                                                            Command="{Binding PreviewCommand}">
                                                                                                        <Border CornerRadius="8"
                                                                                                                ClipToBounds="True">
                                                                                                            <Grid Width="98"
                                                                                                                  Height="98"
                                                                                                                  Background="{StaticResource PanelAltBrush}">
                                                                                                                <Image Stretch="UniformToFill"
                                                                                                                       Source="{Binding ThumbnailSource}" />
                                                                                                            </Grid>
                                                                                                        </Border>
                                                                                                    </Button>
                                                                                                    <TextBlock Margin="0,8,0,0"
                                                                                                               FontSize="12"
                                                                                                               LineHeight="16"
                                                                                                               MaxHeight="32"
                                                                                                               Text="{Binding FileName}"
                                                                                                               TextTrimming="CharacterEllipsis"
                                                                                                               TextWrapping="Wrap" />
                                                                                                </StackPanel>
                                                                                            </Grid>
                                                                                        </Border>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </ScrollViewer>
                                                                    </Grid>
                                                                </Grid>
                                                            </Grid>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <Grid Visibility="{Binding HasTabs, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <Button HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource AccentBrush}"
                                        Style="{StaticResource FlatButtonStyle}"
                                        Command="{Binding ChooseFolderCommand}"
                                        Content="选择文件夹" />
                            </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Row="3"
                                Grid.Column="2"
                                Padding="12"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Background="{StaticResource PanelAltBrush}"
                                        CornerRadius="8"
                                        MinHeight="320"
                                        Margin="0,2,0,0">
                                    <Grid>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="点击当前目录中的图片，在这里查看完整预览。"
                                                   Visibility="{Binding HasPreviewImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        <Viewbox Visibility="{Binding HasPreviewImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 Stretch="Uniform"
                                                 StretchDirection="Both">
                                            <Image Margin="10"
                                                   SnapsToDevicePixels="True"
                                                   Stretch="Uniform"
                                                   UseLayoutRounding="True"
                                                   RenderOptions.BitmapScalingMode="Fant"
                                                   Source="{Binding PreviewImageSource}" />
                                        </Viewbox>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="1"
                                            Margin="2,12,2,0">
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="未选择图片"
                                               Visibility="{Binding HasPreviewImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="点击左侧图片进行选中，并在这里查看大图。"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasPreviewImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding PreviewMeta}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasPreviewImage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                </Grid>
            </Grid>

            <Border Visibility="{Binding IsImageGenerateSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="&#x56FE;&#x7247;&#x751F;&#x6210;" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding GenerationPageDescription}"
                                   TextWrapping="Wrap" />

                        <WrapPanel Margin="0,12,0,0">
                            <Button Padding="12,5"
                                    Command="{Binding ShowTemplateGenerateTabCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTemplateGenerateTabSelected}" Value="True">
                                                <Setter Property="Background" Value="#2D6AE3" />
                                                <Setter Property="BorderBrush" Value="#2D6AE3" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="模板生图" />
                            </Button>
                            <Button Margin="8,0,0,0"
                                    Padding="12,5"
                                    Command="{Binding ShowSpBatchTabCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSpBatchTabSelected}" Value="True">
                                                <Setter Property="Background" Value="#2D6AE3" />
                                                <Setter Property="BorderBrush" Value="#2D6AE3" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="SP批处理" />
                            </Button>
                        </WrapPanel>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.95*" />
                            <ColumnDefinition Width="1.05*" />
                        </Grid.ColumnDefinitions>

                        <Border Margin="0,0,12,0"
                                Padding="14"
                                Background="{StaticResource PanelAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid Visibility="{Binding IsTemplateGenerateTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="模板生图" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,6"
                                               Text="模板库" />
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 IsReadOnly="True"
                                                 Style="{StaticResource ElementInputTextBoxStyle}"
                                                 Text="{Binding TemplateLibraryPath, Mode=OneWay}" />
                                        <Button Grid.Column="1"
                                                Margin="6,0,0,0"
                                                Content="选择模板库"
                                                Style="{StaticResource ElementSecondaryButtonStyle}"
                                                Command="{Binding ChooseTemplateLibraryCommand}" />
                                    </Grid>

                                    <TextBlock Grid.Row="3"
                                               Margin="0,10,0,6"
                                               Text="输出目录" />
                                    <Grid Grid.Row="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource ElementInputTextBoxStyle}"
                                                     Text="{Binding GenerationOutputDirectory, Mode=OneWay}" />
                                            <Button Grid.Column="1"
                                                    Margin="6,0,0,0"
                                                    Content="选择目录"
                                                    Style="{StaticResource ElementSecondaryButtonStyle}"
                                                    Command="{Binding ChooseGenerationOutputFolderCommand}" />
                                            <Button Grid.Column="2"
                                                    Margin="6,0,0,0"
                                                    Content="打开目录"
                                                    Style="{StaticResource ElementSecondaryButtonStyle}"
                                                    Command="{Binding OpenGenerationOutputFolderCommand}" />
                                        </Grid>

                                        <Grid Grid.Row="1"
                                              Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="1*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        Margin="0,0,8,0">
                                                <TextBlock Margin="0,0,0,6"
                                                           Text="生成数量" />
                                                <TextBox Style="{StaticResource ElementInputTextBoxStyle}"
                                                         Text="{Binding GenerationCountText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,0,0,6"
                                                           Text="并发数" />
                                                <TextBox Style="{StaticResource ElementInputTextBoxStyle}"
                                                         Text="{Binding GenerationConcurrencyText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>

                                        <WrapPanel Grid.Row="2"
                                                   Margin="0,10,0,0">
                                            <CheckBox Margin="0,0,16,0"
                                                      VerticalAlignment="Center"
                                                      Content="场景不重复"
                                                      IsChecked="{Binding IsGenerationUniqueScene}" />
                                            <CheckBox VerticalAlignment="Center"
                                                      Content="只出提示词不生图"
                                                      IsChecked="{Binding IsGenerationPromptsOnly}" />
                                        </WrapPanel>

                                        <Border Grid.Row="3"
                                                Margin="0,10,0,0"
                                                Padding="10,8"
                                                Background="#F8FAFD"
                                                BorderBrush="#D9E1EC"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="规则：布局模板随机、场景模板随机，主体跟随所选场景模板所在行，并支持场景不重复。"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="5"
                                                Margin="0,12,0,0">
                                        <Button FontWeight="SemiBold"
                                                Content="开始执行"
                                                Command="{Binding RunTemplateGenerationCommand}" />
                                        <Border Margin="0,10,0,0"
                                                Padding="12"
                                                Background="#FFFFFF"
                                                BorderBrush="#D9E1EC"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding GenerationStatusText}" />
                                                <ProgressBar Margin="0,10,0,0"
                                                             Height="8"
                                                             IsIndeterminate="{Binding IsTemplateGenerating, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Grid Visibility="{Binding IsSpBatchTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="SP批处理" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,6"
                                               Text="输入目录" />
                                    <Grid Grid.Row="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource ElementInputTextBoxStyle}"
                                                     Text="{Binding SpBatchInputDirectory, Mode=OneWay}" />
                                            <Button Grid.Column="1"
                                                    Margin="6,0,0,0"
                                                    Content="选择文件夹"
                                                    Style="{StaticResource ElementSecondaryButtonStyle}"
                                                    Command="{Binding ChooseSpBatchInputFolderCommand}" />
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,10,0,6"
                                                   Text="输出目录" />
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource ElementInputTextBoxStyle}"
                                                     Text="{Binding SpBatchOutputDirectory, Mode=OneWay}" />
                                            <Button Grid.Column="1"
                                                    Margin="6,0,0,0"
                                                    Content="选择目录"
                                                    Style="{StaticResource ElementSecondaryButtonStyle}"
                                                    Command="{Binding ChooseSpBatchOutputFolderCommand}" />
                                            <Button Grid.Column="2"
                                                    Margin="6,0,0,0"
                                                    Content="打开目录"
                                                    Style="{StaticResource ElementSecondaryButtonStyle}"
                                                    Command="{Binding OpenSpBatchOutputFolderCommand}" />
                                        </Grid>

                                        <Grid Grid.Row="3"
                                              Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="1*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        Margin="0,0,8,0">
                                                <TextBlock Margin="0,0,0,6"
                                                           Text="并发数" />
                                                <TextBox Style="{StaticResource ElementInputTextBoxStyle}"
                                                         Text="{Binding SpBatchConcurrencyText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,0,0,6"
                                                           Text="重试次数" />
                                                <TextBox Style="{StaticResource ElementInputTextBoxStyle}"
                                                         Text="{Binding SpBatchRetriesText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>

                                    <StackPanel Grid.Row="3"
                                                Margin="0,10,0,0">
                                        <TextBlock Margin="0,0,0,6"
                                                   Text="运行模式" />
                                        <StackPanel>
                                            <RadioButton Margin="0,0,0,6"
                                                         Content="仅预检查"
                                                         GroupName="SpBatchModeGroup"
                                                         IsChecked="{Binding IsSpBatchDryRun}" />
                                            <RadioButton Margin="0,0,0,6"
                                                         Content="仅建结构"
                                                         GroupName="SpBatchModeGroup"
                                                         IsChecked="{Binding IsSpBatchPrepareOnly}" />
                                            <RadioButton Content="正式生成"
                                                         GroupName="SpBatchModeGroup"
                                                         IsChecked="{Binding IsSpBatchGenerateMode}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Row="4"
                                            Margin="0,10,0,0"
                                            Padding="10,8"
                                            Background="#F8FAFD"
                                            BorderBrush="#D9E1EC"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="固定规则：自动创建当天日期目录、自动生成 SP01/SP02...、自动创建 main/sku/detail，并生成 6 色 SKU 图。"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <StackPanel Grid.Row="5"
                                                Margin="0,12,0,0">
                                        <Button FontWeight="SemiBold"
                                                Content="开始执行"
                                                Command="{Binding RunSpBatchCommand}" />
                                        <Border Margin="0,10,0,0"
                                                Padding="12"
                                                Background="#FFFFFF"
                                                BorderBrush="#D9E1EC"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SpBatchStatusText}" />
                                                <ProgressBar Margin="0,10,0,0"
                                                             Height="8"
                                                             IsIndeterminate="{Binding IsSpBatchRunning, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Padding="14"
                                Background="{StaticResource PanelAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="执行结果" />

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,0">
                                    <Grid Visibility="{Binding IsTemplateGenerateTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Padding="12,10"
                                                Background="#FFFFFF"
                                                BorderBrush="#D9E1EC"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding GenerationResultModeText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding GenerationResultOutputText}" />
                                            </StackPanel>
                                        </Border>

                                        <Grid Grid.Row="1"
                                              Margin="0,8,0,0">
                                            <TextBox IsReadOnly="True"
                                                     Visibility="{Binding HasAnyGenerationResultCards, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                     Style="{StaticResource MultiLineTextBoxStyle}"
                                                     Text="{Binding GenerationResultText, Mode=OneWay}" />

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Visibility="{Binding HasGenerationPromptCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl ItemsSource="{Binding GenerationPromptCards}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:GenerationPromptCardViewModel}">
                                                            <Border Margin="0,0,0,8"
                                                                    Padding="12,10"
                                                                    Background="#FFFFFF"
                                                                    BorderBrush="#D9E1EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="14"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding Title}" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="{StaticResource TitleTextBrush}"
                                                                               Text="{Binding PromptText}"
                                                                               TextWrapping="Wrap" />
                                                                    <Border Margin="0,6,0,0"
                                                                            Padding="10,8"
                                                                            Background="#F8FAFD"
                                                                            BorderBrush="#E3EAF4"
                                                                            BorderThickness="1"
                                                                            CornerRadius="6"
                                                                            Visibility="{Binding HasMeta, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                                                   Text="{Binding MetaText}"
                                                                                   TextWrapping="Wrap" />
                                                                    </Border>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Visibility="{Binding HasGeneratedImageResultCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl ItemsSource="{Binding GeneratedImageResultCards}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:GeneratedImageResultCardViewModel}">
                                                            <Border Width="116"
                                                                    Margin="0,0,8,8"
                                                                    Padding="8"
                                                                    Background="White"
                                                                    BorderBrush="#D9E1EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <Button Padding="0"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Command="{Binding OpenFileCommand}"
                                                                        Style="{StaticResource FlatButtonStyle}">
                                                                    <StackPanel>
                                                                        <Border CornerRadius="8"
                                                                                ClipToBounds="True">
                                                                            <Grid Width="98"
                                                                                  Height="98"
                                                                                  Background="{StaticResource PanelAltBrush}">
                                                                                <Image Stretch="UniformToFill"
                                                                                       Source="{Binding ThumbnailSource}" />
                                                                            </Grid>
                                                                        </Border>
                                                                        <TextBlock Margin="0,8,0,0"
                                                                                   FontSize="12"
                                                                                   LineHeight="16"
                                                                                   MaxHeight="32"
                                                                                   Text="{Binding FileName}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>

                                    <Grid Visibility="{Binding IsSpBatchTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Padding="12,10"
                                                Background="#FFFFFF"
                                                BorderBrush="#D9E1EC"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SpBatchResultRootText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding SpBatchResultStatsText}" />
                                            </StackPanel>
                                        </Border>

                                        <Grid Grid.Row="1"
                                              Margin="0,8,0,0">
                                            <TextBox IsReadOnly="True"
                                                     Visibility="{Binding HasAnySpBatchResultCards, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                     Style="{StaticResource MultiLineTextBoxStyle}"
                                                     Text="{Binding SpBatchSummaryText, Mode=OneWay}" />

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Visibility="{Binding HasSpBatchImageResultCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl ItemsSource="{Binding SpBatchImageResultCards}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:GeneratedImageResultCardViewModel}">
                                                            <Border Width="116"
                                                                    Margin="0,0,8,8"
                                                                    Padding="8"
                                                                    Background="White"
                                                                    BorderBrush="#D9E1EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <Button Padding="0"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Command="{Binding OpenFileCommand}"
                                                                        Style="{StaticResource FlatButtonStyle}">
                                                                    <StackPanel>
                                                                        <Border CornerRadius="8"
                                                                                ClipToBounds="True">
                                                                            <Grid Width="98"
                                                                                  Height="98"
                                                                                  Background="{StaticResource PanelAltBrush}">
                                                                                <Image Stretch="UniformToFill"
                                                                                       Source="{Binding ThumbnailSource}" />
                                                                            </Grid>
                                                                        </Border>
                                                                        <TextBlock Margin="0,8,0,0"
                                                                                   FontSize="12"
                                                                                   LineHeight="16"
                                                                                   MaxHeight="32"
                                                                                   Text="{Binding FileName}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Visibility="{Binding ShouldShowSpBatchDetailCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl ItemsSource="{Binding SpBatchResultCards}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:SpBatchResultCardViewModel}">
                                                            <Border Margin="0,0,0,8"
                                                                    Padding="12,10"
                                                                    Background="#FFFFFF"
                                                                    BorderBrush="#D9E1EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <StackPanel>
                                                                    <DockPanel>
                                                                        <TextBlock FontSize="14"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding Title}" />
                                                                        <Border DockPanel.Dock="Right"
                                                                                Padding="8,2"
                                                                                Background="#F8FAFD"
                                                                                BorderBrush="#E3EAF4"
                                                                                BorderThickness="1"
                                                                                CornerRadius="10">
                                                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                                                       Text="{Binding StatusText}" />
                                                                        </Border>
                                                                    </DockPanel>
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="{StaticResource TitleTextBrush}"
                                                                               Text="{Binding SummaryText}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               Text="{Binding DetailText}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
