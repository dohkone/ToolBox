<Window x:Class="ImageKeeper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ImageKeeper.App.ViewModels"
        mc:Ignorable="d"
        Title="TEMU工具箱"
        Width="1660"
        Height="960"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Margin="0"
                                Background="#C8D1E0"
                                CornerRadius="1.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border x:Name="VerticalRoot"
                                    Margin="0,2,0,2"
                                    Background="#F4F6FA"
                                    CornerRadius="1.5">
                                <Track Name="PART_Track"
                                       IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageUpCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageDownCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>

                            <Border x:Name="HorizontalRoot"
                                    Margin="2,0,2,0"
                                    Background="#F4F6FA"
                                    CornerRadius="1.5"
                                    Visibility="Collapsed">
                                <Track x:Name="HorizontalTrack"
                                       Orientation="Horizontal">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageLeftCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageRightCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="VerticalRoot" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="HorizontalRoot" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="3" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="10,8,10,0"
                Background="#EEF1F6"
                BorderBrush="#D9DEE7"
                BorderThickness="0,0,0,1">
            <ScrollViewer VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Auto">
                <StackPanel Orientation="Horizontal">
                    <ItemsControl ItemsSource="{Binding WorkspaceTabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:WorkspaceTabViewModel}">
                                <Border Margin="0,0,6,0"
                                        Padding="0"
                                        MinWidth="160"
                                        Height="36"
                                        SnapsToDevicePixels="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0F3F7" />
                                            <Setter Property="BorderBrush" Value="#D6DCE8" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="7,7,0,0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="White" />
                                                    <Setter Property="BorderBrush" Value="#2D6AE3" />
                                                    <Setter Property="Margin" Value="0,0,6,-1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Padding="10,6,8,6"
                                                HorizontalContentAlignment="Left"
                                                VerticalContentAlignment="Center"
                                                Style="{StaticResource FlatButtonStyle}"
                                                Command="{Binding ActivateCommand}">
                                            <TextBlock Width="118"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       Text="{Binding Title}" />
                                        </Button>
                                        <Button Grid.Column="1"
                                                Width="24"
                                                Height="24"
                                                Margin="6,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource FlatButtonStyle}"
                                                Foreground="#667085"
                                                FontSize="13"
                                                Command="{Binding CloseCommand}"
                                                Content="×" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Width="36"
                            Height="32"
                            Margin="2,0,0,0"
                            FontSize="20"
                            Command="{Binding AddTabCommand}"
                            Content="+">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Foreground" Value="#1F2A37" />
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Setter Property="BorderBrush" Value="#D6DCE8" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <WrapPanel Grid.Row="1"
                   Margin="14,0,14,10"
                   Orientation="Horizontal">
            <Button Command="{Binding ChooseFolderCommand}"
                    Margin="0,0,8,0"
                    Content="选择文件夹" />
            <Button Command="{Binding SelectBackupFolderCommand}"
                    Margin="0,0,8,0"
                    Background="White"
                    Foreground="#1F2A37"
                    BorderBrush="#D6DCE8"
                    Content="备份位置" />
            <CheckBox Margin="6,8,14,0"
                      VerticalAlignment="Center"
                      Content="包含子文件夹"
                      IsChecked="{Binding IsRecursive}" />
        </WrapPanel>

        <Border Grid.Row="2"
                Margin="14,0,14,12"
                Padding="14,10"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="{Binding LoadedFolderText}" />
                <TextBlock Margin="0,4,0,4"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding SelectionSummaryText}" />
                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding BackupFolderText}" />

                <Border Margin="0,10,0,0"
                        Padding="12,10"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Visibility="{Binding IsLoadingVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding LoadingTitle}" />
                        <TextBlock Margin="0,5,0,8"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding LoadingDetail}"
                                   TextWrapping="Wrap" />
                        <ProgressBar Height="10"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ScanProgressValue, Mode=OneWay}"
                                     IsIndeterminate="{Binding IsScanProgressIndeterminate, Mode=OneWay}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding ScanProgressText}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3"
              Margin="14,0,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid Visibility="{Binding HasTabs, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="NestedScrollViewer_OnPreviewMouseWheel"
                                      Visibility="{Binding HasRootCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding SelectedTab.RootCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:RootCardViewModel}">
                                        <Grid Margin="0,0,0,14">
                                                                                        <Border Padding="14,11"
                                                    Background="{StaticResource SuccessSoftBrush}"
                                                    BorderBrush="{StaticResource SuccessBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Visibility="{Binding IsCollapsed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Padding="0"
                                                            HorizontalContentAlignment="Left"
                                                            VerticalContentAlignment="Center"
                                                            Style="{StaticResource FlatButtonStyle}"
                                                            Command="{Binding ExpandCommand}">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding CollapsedSummaryText}" />
                                                    </Button>
                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal">
                                                        <Button Padding="12,6"
                                                                Margin="0,0,8,0"
                                                                Background="{StaticResource SuccessBrush}"
                                                                BorderBrush="{StaticResource SuccessBrush}"
                                                                Command="{Binding ExpandCommand}"
                                                                Content="编辑" />
                                                        <Button Padding="12,6"
                                                                Background="#2563EB"
                                                                BorderBrush="#2563EB"
                                                                Command="{Binding AutoPublishCommand}"
                                                                Content="自动上架" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Padding="0"
                                                    Background="White"
                                                    BorderBrush="{Binding CardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <Grid Margin="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="185" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Background="White"
                                                                BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="0,0,1,0"
                                                                CornerRadius="8,0,0,8"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>

                                                                <Grid Margin="2,6,2,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="18" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <Button Grid.Column="0"
                                                                            Padding="0"
                                                                            Width="16"
                                                                            Height="16"
                                                                            VerticalAlignment="Center"
                                                                            HorizontalAlignment="Left"
                                                                            FontSize="12"
                                                                            FontWeight="Bold"
                                                                            Foreground="{StaticResource MutedTextBrush}"
                                                                            Style="{StaticResource FlatButtonStyle}"
                                                                            Command="{Binding ToggleExpandCommand}"
                                                                            CommandParameter="{Binding RootNode}"
                                                                            Content="{Binding RootNode.ExpandGlyph}" />
                                                                    <TextBlock Grid.Column="1"
                                                                               VerticalAlignment="Center"
                                                                               FontSize="15"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TitleTextBrush}"
                                                                               Text="{Binding DisplayName}" />
                                                                </Grid>

                                                                <ScrollViewer Grid.Row="1"
                                                                              VerticalScrollBarVisibility="Auto"
                                                                              HorizontalScrollBarVisibility="Disabled"
                                                                              Padding="0,6,0,8"
                                                                              PreviewMouseWheel="NestedScrollViewer_OnPreviewMouseWheel">
                                                                    <ItemsControl ItemsSource="{Binding ChildFolders}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type viewModels:FolderNodeViewModel}">
                                                                                <Button Margin="8,0,8,10"
                                                                                        Padding="0"
                                                                                        HorizontalContentAlignment="Stretch"
                                                                                        VerticalContentAlignment="Stretch"
                                                                                        Style="{StaticResource FlatButtonStyle}"
                                                                                        Command="{Binding DataContext.SelectNodeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                        CommandParameter="{Binding}">
                                                                                    <Border MinHeight="40"
                                                                                            Padding="10,9"
                                                                                            Background="{Binding RowBackground}"
                                                                                            BorderBrush="{Binding RowBorderBrush}"
                                                                                            BorderThickness="1"
                                                                                            CornerRadius="8">
                                                                                        <Grid>
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="*" />
                                                                                                <ColumnDefinition Width="Auto" />
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <TextBlock VerticalAlignment="Center"
                                                                                                       FontSize="14"
                                                                                                       FontWeight="SemiBold"
                                                                                                       Foreground="{Binding NameForeground}"
                                                                                                       Text="{Binding DisplayName}" />
                                                                                            <TextBlock Grid.Column="1"
                                                                                                       Margin="14,0,0,0"
                                                                                                       VerticalAlignment="Center"
                                                                                                       FontSize="13"
                                                                                                       Foreground="{Binding CountForeground}"
                                                                                                       Text="{Binding ImageCountText}" />
                                                                                        </Grid>
                                                                                    </Border>
                                                                                </Button>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </ScrollViewer>
                                                            </Grid>
                                                        </Border>

                                                        <Border Grid.Column="1"
                                                                AllowDrop="True"
                                                                Background="{Binding ContentBackgroundBrush}"
                                                                CornerRadius="0,8,8,0"
                                                                ClipToBounds="True"
                                                                DragEnter="WorkspaceContentBorder_OnDragEnter"
                                                                DragLeave="WorkspaceContentBorder_OnDragLeave"
                                                                DragOver="WorkspaceContentBorder_OnDragOver"
                                                                Drop="WorkspaceContentBorder_OnDrop">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                                    <Setter Property="BorderThickness" Value="0" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#2D6AE3" />
                                                                            <Setter Property="BorderThickness" Value="2" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid Margin="2,4,2,4"
                                                                  ClipToBounds="True">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <WrapPanel Grid.Column="1"
                                                                               Margin="12,0,0,0"
                                                                               HorizontalAlignment="Right"
                                                                               Orientation="Horizontal">
                                                                        <Button Command="{Binding AddImagesCommand}"
                                                                                Margin="0,0,8,0"
                                                                                Background="White"
                                                                                Foreground="#1F2A37"
                                                                                BorderBrush="#D6DCE8"
                                                                                Content="添加图片" />
                                                                        <Button Command="{Binding MoveSelectedCommand}"
                                                                                Margin="0,0,8,0"
                                                                                Background="#FFF5F5"
                                                                                Foreground="#D14343"
                                                                                BorderBrush="#F5C2C2"
                                                                                Content="移动选中" />
                                                                        <Button Command="{Binding CollapseCommand}"
                                                                                Background="#0F8A4B"
                                                                                BorderBrush="#0F8A4B"
                                                                                Content="已修改" />
                                                                    </WrapPanel>
                                                                </Grid>

                                                                <TextBlock Grid.Row="1"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="14"
                                                                           Foreground="{StaticResource MutedTextBrush}"
                                                                           Text="{Binding ContentEmptyText}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"
                                                                           Visibility="{Binding HasImages, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                                                                <ScrollViewer Grid.Row="1"
                                                                              Margin="0,8,0,0"
                                                                              VerticalScrollBarVisibility="Auto"
                                                                              HorizontalScrollBarVisibility="Disabled"
                                                                              Visibility="{Binding HasImages, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                              PreviewMouseWheel="NestedScrollViewer_OnPreviewMouseWheel">
                                                                    <StackPanel>
                                                                        <DockPanel Margin="0,0,0,10">
                                                                            <Button DockPanel.Dock="Right"
                                                                                    Padding="12,6"
                                                                                    Background="#2563EB"
                                                                                    BorderBrush="#2563EB"
                                                                                    Command="{Binding LoadMoreImagesCommand}"
                                                                                    Content="继续加载"
                                                                                    Visibility="{Binding HasMoreImages, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                        </DockPanel>

                                                                        <ItemsControl ItemsSource="{Binding CurrentImages}">
                                                                            <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <WrapPanel />
                                                                                </ItemsPanelTemplate>
                                                                            </ItemsControl.ItemsPanel>
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate DataType="{x:Type viewModels:ImageItemViewModel}">
                                                                                    <Border Width="146"
                                                                                            Margin="0,0,12,12"
                                                                                            Padding="8"
                                                                                            Background="{Binding CardBackground}"
                                                                                            BorderBrush="{Binding CardBorderBrush}"
                                                                                            BorderThickness="1"
                                                                                            CornerRadius="8">
                                                                                        <Border.ContextMenu>
                                                                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                                                                <MenuItem Header="打开图片"
                                                                                                          Command="{Binding OpenFileCommand}" />
                                                                                                <MenuItem Header="打开图片所在文件夹"
                                                                                                          Command="{Binding OpenContainingFolderCommand}" />
                                                                                                <Separator />
                                                                                                <MenuItem Header="复制图片路径"
                                                                                                          Command="{Binding CopyPathCommand}" />
                                                                                            </ContextMenu>
                                                                                        </Border.ContextMenu>
                                                                                            <Grid>
                                                                                                <Grid.RowDefinitions>
                                                                                                    <RowDefinition Height="Auto" />
                                                                                                    <RowDefinition Height="Auto" />
                                                                                                </Grid.RowDefinitions>

                                                                                            <CheckBox HorizontalAlignment="Right"
                                                                                                      VerticalAlignment="Top"
                                                                                                      Margin="0,-2,0,0"
                                                                                                      Content="选中"
                                                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                                                                            <StackPanel Grid.Row="1">
                                                                                                <Button Margin="0,8,0,0"
                                                                                                        Padding="0"
                                                                                                        HorizontalContentAlignment="Stretch"
                                                                                                        VerticalContentAlignment="Stretch"
                                                                                                        Style="{StaticResource FlatButtonStyle}"
                                                                                                        Command="{Binding PreviewCommand}">
                                                                                                    <Border CornerRadius="8"
                                                                                                            ClipToBounds="True">
                                                                                                        <Grid Width="128"
                                                                                                              Height="128"
                                                                                                              Background="{StaticResource PanelAltBrush}">
                                                                                                            <Image Stretch="UniformToFill"
                                                                                                                   Source="{Binding ThumbnailSource}" />
                                                                                                        </Grid>
                                                                                                    </Border>
                                                                                                </Button>
                                                                                                <TextBlock Margin="0,8,0,0"
                                                                                                           Text="{Binding FileName}"
                                                                                                           FontSize="12"
                                                                                                           LineHeight="16"
                                                                                                           TextWrapping="Wrap"
                                                                                                           MaxHeight="34"
                                                                                                           TextTrimming="CharacterEllipsis" />
                                                                                            </StackPanel>
                                                                                        </Grid>
                                                                                    </Border>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </ScrollViewer>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <Grid Visibility="{Binding HasTabs, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Button HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource AccentBrush}"
                                Style="{StaticResource FlatButtonStyle}"
                                Command="{Binding ChooseFolderCommand}"
                                Content="选择文件夹" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="14,0,0,0"
                    Padding="14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelAltBrush}"
                            CornerRadius="7"
                            MinHeight="320">
                        <Grid>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="点击当前目录中的图片，在这里查看完整预览。"
                                       Visibility="{Binding HasPreviewImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            <Viewbox Visibility="{Binding HasPreviewImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     Stretch="Uniform"
                                     StretchDirection="Both">
                                <Image Margin="10"
                                       SnapsToDevicePixels="True"
                                       Stretch="Uniform"
                                       UseLayoutRounding="True"
                                       RenderOptions.BitmapScalingMode="Fant"
                                       Source="{Binding PreviewImageSource}" />
                            </Viewbox>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="0,12,0,0">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding PreviewMeta}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

