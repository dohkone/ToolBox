<Window x:Class="ImageKeeper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ImageKeeper.Core.Models;assembly=ImageKeeper.Core"
        xmlns:viewModels="clr-namespace:ImageKeeper.App.ViewModels"
        mc:Ignorable="d"
        Title="EcomTool Studio"
        Icon="pack://application:,,,/Assets/new_logo.ico"
        Width="1660"
        Height="960"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#EEEEEE"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border x:Name="VerticalRoot"
                                    Margin="0,2,0,2"
                                    Background="#EEF2F8"
                                    CornerRadius="3">
                                <Track Name="PART_Track"
                                       IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageUpCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageDownCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>

                            <Border x:Name="HorizontalRoot"
                                    Margin="2,0,2,0"
                                    Background="#EEF2F8"
                                    CornerRadius="3"
                                    Visibility="Collapsed">
                                <Track Orientation="Horizontal">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageLeftCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageRightCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="VerticalRoot" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="HorizontalRoot" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Padding" Value="8,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Width" Value="508" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#303133" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#1F2A37" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D6DCE8" />
        </Style>

        <Style x:Key="StatusFilterButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="CollapsedCardPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="CollapsedCardSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="62" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D6DCE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ElementInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#DCDFE6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MultiLineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="ElementSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCDFE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ElementPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#409EFF" />
            <Setter Property="BorderBrush" Value="#409EFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostIconButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F2F6FC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E6EEF8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

        <Grid Background="{StaticResource AppBackgroundBrush}">
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="12,16,0,16"
              Background="{StaticResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Button Command="{Binding ShowImageGenerateCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImageGenerateSelected}" Value="True">
                                    <Setter Property="Background" Value="#EEEEEE" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="AI&#29983;&#22270;" />
                </Button>

                <Button Command="{Binding ShowReviewWorkspaceCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReviewWorkspaceSelected}" Value="True">
                                    <Setter Property="Background" Value="#EEEEEE" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#22270;&#29255;&#22788;&#29702;" />
                </Button>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Margin="12,0,0,0"
                       HorizontalAlignment="Left"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="11"
                       Text="ToolBox" />
        </Grid>

        <Grid Grid.Column="1"
              Margin="12,12,12,12"
              Background="{StaticResource AppBackgroundBrush}">
            <Grid Background="{StaticResource AppBackgroundBrush}"
                  Visibility="{Binding IsReviewWorkspaceSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="352" />
                </Grid.ColumnDefinitions>

                <Grid Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2" />
                        <ColumnDefinition Width="346" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,0"
                            Padding="0,0,0,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                        <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Horizontal">
                                <ItemsControl ItemsSource="{Binding WorkspaceTabs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:WorkspaceTabViewModel}">
                                            <Border Margin="0,0,8,0"
                                                    MinWidth="168"
                                                    Height="36">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFFFFF" />
                                                        <Setter Property="BorderBrush" Value="#C8D7F4" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="CornerRadius" Value="8,8,0,0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="White" />
                                                                <Setter Property="BorderBrush" Value="#2D6AE3" />
                                                                <Setter Property="Margin" Value="0,0,8,-1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Padding="10,6,4,6"
                                                            HorizontalContentAlignment="Left"
                                                            VerticalContentAlignment="Center"
                                                            Style="{StaticResource FlatButtonStyle}"
                                                            Command="{Binding ActivateCommand}">
                                                        <TextBlock Width="120"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Text="{Binding Title}" />
                                                    </Button>
                                                    <Button Grid.Column="1"
                                                            Width="22"
                                                            Height="22"
                                                            Margin="2,0,8,0"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Style="{StaticResource FlatButtonStyle}"
                                                            Foreground="#667085"
                                                            FontSize="12"
                                                            Command="{Binding CloseCommand}"
                                                            Content="×" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Margin="0,0,0,2"
                                        Command="{Binding AddTabCommand}"
                                        Style="{StaticResource SmallIconButtonStyle}"
                                        Content="+" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,6"
                            Padding="14,8"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="{Binding LoadedFolderText}" />
                            <TextBlock Margin="0,2,0,2"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding SelectionSummaryText}" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding BackupFolderText}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,4"
                            Padding="14,8"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal">
                                <Button Command="{Binding ChooseFolderCommand}"
                                        Margin="0,0,8,0"
                                        Content="选择文件夹" />
                                <Button Command="{Binding SelectBackupFolderCommand}"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="备份位置" />
                                <Button Command="{Binding SelectAllBatchCardsCommand}"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="全部选中" />
                                <Button Command="{Binding ClearAllBatchCardsCommand}"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="全部取消" />
                                <Button Margin="0,0,8,0"
                                        Command="{Binding RunBatchAutoPublishCommand}"
                                        Background="#409EFF"
                                        BorderBrush="#409EFF"
                                        IsEnabled="{Binding CanRunBatchAutoPublish}"
                                        Content="批量上架">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}" />
                                    </Button.Style>
                                </Button>
                            </WrapPanel>

                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.Column="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel Grid.Row="0"
                                       Margin="12,4,12,0"
                                       Orientation="Horizontal">
                                <TextBlock Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="状态筛选" />
                                <Button Command="{Binding SetAutoPublishStatusFilterCommand}"
                                        CommandParameter="{x:Static models:AutoPublishStatusFilter.All}"
                                        Content="{Binding AllStatusFilterText}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StatusFilterButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAllStatusFilterSelected}" Value="True">
                                                    <Setter Property="Background" Value="#EEEEEE" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding SetAutoPublishStatusFilterCommand}"
                                        CommandParameter="{x:Static models:AutoPublishStatusFilter.NotPublished}"
                                        Content="{Binding NotPublishedStatusFilterText}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StatusFilterButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNotPublishedStatusFilterSelected}" Value="True">
                                                    <Setter Property="Background" Value="#EEEEEE" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding SetAutoPublishStatusFilterCommand}"
                                        CommandParameter="{x:Static models:AutoPublishStatusFilter.Publishing}"
                                        Content="{Binding PublishingStatusFilterText}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StatusFilterButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPublishingStatusFilterSelected}" Value="True">
                                                    <Setter Property="Background" Value="#EEEEEE" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding SetAutoPublishStatusFilterCommand}"
                                        CommandParameter="{x:Static models:AutoPublishStatusFilter.Success}"
                                        Content="{Binding SuccessStatusFilterText}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StatusFilterButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSuccessStatusFilterSelected}" Value="True">
                                                    <Setter Property="Background" Value="#EEEEEE" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding SetAutoPublishStatusFilterCommand}"
                                        CommandParameter="{x:Static models:AutoPublishStatusFilter.Failed}"
                                        Content="{Binding FailedStatusFilterText}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource StatusFilterButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFailedStatusFilterSelected}" Value="True">
                                                    <Setter Property="Background" Value="#EEEEEE" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                            <Grid Grid.Row="1"
                                  Visibility="{Binding HasTabs, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="12,8,12,12">
                                    <ItemsControl ItemsSource="{Binding SelectedTab.FilteredRootCards}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewModels:RootCardViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid Visibility="{Binding IsCollapsed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Border Background="{Binding AutoPublishStatusBackground}"
                                                                BorderBrush="{Binding AutoPublishStatusBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="14,9">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0"
                                                                          Margin="0,0,12,0"
                                                                          VerticalAlignment="Center"
                                                                          IsChecked="{Binding IsBatchSelected, Mode=TwoWay}"
                                                                          Visibility="{Binding CanBatchSelect, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <Button Grid.Column="1"
                                                                        HorizontalContentAlignment="Left"
                                                                        Style="{StaticResource FlatButtonStyle}"
                                                                        Command="{Binding ExpandCommand}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock VerticalAlignment="Center"
                                                                                   FontSize="13"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding CollapsedSummaryText}" />
                                                                        <Border Margin="12,0,0,0"
                                                                                Padding="7,2"
                                                                                VerticalAlignment="Center"
                                                                                Background="{Binding AutoPublishStatusBackground}"
                                                                                BorderBrush="{Binding AutoPublishStatusBorderBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="9">
                                                                            <TextBlock FontSize="12"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{Binding AutoPublishStatusForeground}"
                                                                                       Text="{Binding AutoPublishStatusText}" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                </Button>
                                                                <StackPanel Grid.Column="2"
                                                                            Orientation="Horizontal">
                                                                    <Button Margin="0,0,8,0"
                                                                            Content="自动上架"
                                                                            Style="{StaticResource CollapsedCardPrimaryButtonStyle}"
                                                                            Command="{Binding AutoPublishCommand}" />
                                                                    <Button Content="编辑"
                                                                            Style="{StaticResource CollapsedCardSecondaryButtonStyle}"
                                                                            Command="{Binding ExpandCommand}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>

                                                    <Border Padding="8"
                                                            Background="#FFFFFF"
                                                            BorderBrush="#D9E1EC"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                        <Grid>
                                                            <Grid Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
