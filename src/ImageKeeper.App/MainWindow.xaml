                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    PreviewMouseLeftButtonDown="SpBatchSourceCard_PreviewMouseLeftButtonDown">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>
                                                                    <Button HorizontalAlignment="Right"
                                                                            VerticalAlignment="Top"
                                                                            Margin="0,-4,-4,0"
                                                                            Width="20"
                                                                            Height="20"
                                                                            MinWidth="20"
                                                                            Padding="0"
                                                                            Style="{StaticResource GhostIconButtonStyle}"
                                                                            Command="{Binding RemoveCommand}">
                                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                                   FontSize="11"
                                                                                   Foreground="#909399"
                                                                                   Text="&#xE711;" />
                                                                    </Button>
                                                                    <StackPanel Grid.Row="1">
                                                                        <Border CornerRadius="8"
                                                                                ClipToBounds="True">
                                                                            <Grid Width="98"
                                                                                  Height="98"
                                                                                  Background="{StaticResource PanelAltBrush}">
                                                                                <Image Stretch="UniformToFill"
                                                                                       Source="{Binding ThumbnailSource}" />
                                                                            </Grid>
                                                                        </Border>
                                                                        <TextBlock Margin="0,8,0,0"
                                                                                   FontSize="12"
                                                                                   LineHeight="16"
                                                                                   MaxHeight="32"
                                                                                   Text="{Binding FileName}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <Border Background="#F7F8FA"
                                                    BorderBrush="#D9E1EC"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Visibility="{Binding HasSpBatchSourceImageCards, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="把模板生图里选中的图片带到这里，或直接拖拽图片到此区域。" />
                                                </Grid>
                                            </Border>

                                            <Border Background="#EEF2F8"
                                                    BorderBrush="#D0D7E2"
                                                    BorderThickness="2"
                                                    CornerRadius="8"
                                                    Visibility="{Binding IsSpBatchStagingDropTarget, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#606266"
                                                               Text="松开鼠标，将图片添加到 SP 批处理区域" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="2"
                                          Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,8,0">
                                            <TextBlock Margin="0,0,0,6"
                                                       Text="输出目录" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         IsReadOnly="True"
                                                         Style="{StaticResource ElementInputTextBoxStyle}"
                                                         Text="{Binding SpBatchOutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="1"
                                                        Margin="6,0,0,0"
                                                        Content="选择目录"
                                                        Style="{StaticResource ElementSecondaryButtonStyle}"
                                                        Command="{Binding ChooseSpBatchOutputFolderCommand}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Margin="8,0,0,0">
                                            <TextBlock Margin="0,0,0,6"
                                                       Text="并发数量" />
                                            <TextBox HorizontalAlignment="Stretch"
                                                     Style="{StaticResource ElementInputTextBoxStyle}"
                                                     Text="{Binding SpBatchConcurrencyText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Row="3"
                                                Margin="0,10,0,0">
                                        <TextBlock Margin="0,0,0,6"
                                                   Text="运行模式" />
                                        <WrapPanel>
                                            <RadioButton Margin="0,0,18,0"
                                                         Content="仅预检查"
                                                         GroupName="SpBatchModeGroup"
                                                         IsChecked="{Binding IsSpBatchDryRun}" />
                                            <RadioButton Margin="0,0,18,0"
                                                         Content="仅建结构"
                                                         GroupName="SpBatchModeGroup"
                                                         IsChecked="{Binding IsSpBatchPrepareOnly}" />
                                            <RadioButton Content="正式生成"
                                                         GroupName="SpBatchModeGroup"
                                                         IsChecked="{Binding IsSpBatchGenerateMode}" />
                                        </WrapPanel>

                                        <Button Margin="0,12,0,0"
                                                FontWeight="SemiBold"
                                                Content="开始执行"
                                                Command="{Binding RunSpBatchCommand}" />
                                        <Border Margin="0,10,0,0"
                                                Padding="12"
                                                Background="#FFFFFF"
                                                BorderBrush="#D9E1EC"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SpBatchStatusText}" />
                                                <ProgressBar Margin="0,10,0,0"
                                                             Height="8"
                                                             IsIndeterminate="{Binding IsSpBatchRunning, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1"
                                Padding="14"
                                Background="{StaticResource PanelAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="执行结果" />

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,0">
                                    <Grid Visibility="{Binding IsTemplateGenerateTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0"
                                              Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    MinWidth="96"
                                                    Margin="0,0,8,0"
                                                    FontWeight="SemiBold"
                                                    Content="生成SKU图"
                                                    Command="{Binding SendSelectedImagesToSpBatchCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ElementSecondaryButtonStyle}">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanGenerateSkuFromTemplate}" Value="False">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Grid.Column="1"
                                                    MinWidth="96"
                                                    Content="选择图片"
                                                    Style="{StaticResource ElementSecondaryButtonStyle}"
                                                    Command="{Binding ChooseGenerationImagesCommand}" />
                                        </Grid>

                                        <Grid Grid.Row="1"
                                              Margin="0,8,0,0">
                                            <Border Visibility="{Binding HasAnyGenerationResultCards, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#D9E1EC"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="16">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="这里会显示生成结果卡片。"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Visibility="{Binding HasGenerationPromptCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl ItemsSource="{Binding GenerationPromptCards}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:GenerationPromptCardViewModel}">
                                                            <Border Margin="0,0,0,8"
                                                                    Padding="12,10"
                                                                    Background="#FFFFFF"
                                                                    BorderBrush="#D9E1EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>

                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   FontSize="14"
                                                                                   FontWeight="SemiBold"
                                                                                   VerticalAlignment="Center"
                                                                                   Text="{Binding Title}" />
                                                                        <Button Grid.Column="1"
                                                                                Style="{StaticResource GhostIconButtonStyle}"
                                                                                Command="{Binding CopyPromptCommand}">
                                                                            <TextBlock HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       FontFamily="Segoe MDL2 Assets"
                                                                                       FontSize="15">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value="&#xE8C8;" />
                                                                                        <Setter Property="Foreground" Value="#606266" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsCopied}" Value="True">
                                                                                                <Setter Property="Text" Value="&#xE73E;" />
                                                                                                <Setter Property="Foreground" Value="#67C23A" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Button>
                                                                    </Grid>

                                                                    <Border Grid.Row="1"
                                                                            Margin="0,8,0,0"
                                                                            Padding="10,8"
                                                                            Background="#F8FAFD"
                                                                            BorderBrush="#E3EAF4"
                                                                            BorderThickness="1"
                                                                            CornerRadius="6">
                                                                        <TextBlock Foreground="{StaticResource TitleTextBrush}"
                                                                                   Text="{Binding PromptText}"
                                                                                   TextWrapping="Wrap" />
                                                                    </Border>

                                                                    <Border Grid.Row="2"
                                                                            Margin="0,8,0,0"
                                                                            Padding="10,8"
                                                                            Background="#F8FAFD"
                                                                            BorderBrush="#E3EAF4"
                                                                            BorderThickness="1"
                                                                            CornerRadius="6"
                                                                            Visibility="{Binding HasMeta, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                                                   Text="{Binding MetaText}"
                                                                                   TextWrapping="Wrap" />
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Visibility="{Binding HasGeneratedImageResultCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl ItemsSource="{Binding GeneratedImageResultCards}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:GeneratedImageResultCardViewModel}">
                                                            <Border Width="116"
                                                                    Margin="0,0,8,8"
                                                                    Padding="8"
                                                                    CornerRadius="8"
                                                                    PreviewMouseLeftButtonDown="GeneratedImageCard_PreviewMouseLeftButtonDown">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="White" />
                                                                        <Setter Property="BorderBrush" Value="#D9E1EC" />
                                                                        <Setter Property="BorderThickness" Value="1" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                <Setter Property="Background" Value="#EEEEEE" />
                                                                                <Setter Property="BorderBrush" Value="#D0D0D0" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>
                                                                    <Button HorizontalAlignment="Right"
                                                                            VerticalAlignment="Top"
                                                                            Margin="0,-4,-4,0"
                                                                            Width="20"
                                                                            Height="20"
                                                                            MinWidth="20"
                                                                            Padding="0"
                                                                            Style="{StaticResource GhostIconButtonStyle}"
                                                                            Command="{Binding RemoveCommand}">
                                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                                   FontSize="11"
                                                                                   Foreground="#909399"
                                                                                   Text="&#xE711;" />
                                                                    </Button>
                                                                    <StackPanel Grid.Row="1">
                                                                        <Border CornerRadius="8"
                                                                                ClipToBounds="True">
                                                                            <Grid Width="98"
                                                                                  Height="98"
                                                                                  Background="{StaticResource PanelAltBrush}">
                                                                                <Image Stretch="UniformToFill"
                                                                                       Source="{Binding ThumbnailSource}" />
                                                                            </Grid>
                                                                        </Border>
                                                                        <TextBlock Margin="0,8,0,0"
                                                                                   FontSize="12"
                                                                                   LineHeight="16"
                                                                                   MaxHeight="32"
                                                                                   Text="{Binding FileName}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>

                                    <Grid Visibility="{Binding IsSpBatchTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Padding="12,10"
                                                Background="#FFFFFF"
                                                BorderBrush="#D9E1EC"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SpBatchResultRootText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding SpBatchResultStatsText}" />
                                            </StackPanel>
                                        </Border>

                                        <Grid Grid.Row="1"
                                              Margin="0,8,0,0">
                                            <TextBox IsReadOnly="True"
                                                     Visibility="{Binding HasAnySpBatchResultCards, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                     Style="{StaticResource MultiLineTextBoxStyle}"
                                                     Text="{Binding SpBatchSummaryText, Mode=OneWay}" />

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Visibility="{Binding HasSpBatchImageResultCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl ItemsSource="{Binding SpBatchImageResultCards}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:GeneratedImageResultCardViewModel}">
                                                            <Border Width="116"
                                                                    Margin="0,0,8,8"
                                                                    Padding="8"
                                                                    Background="White"
                                                                    BorderBrush="#D9E1EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <Button Padding="0"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Command="{Binding OpenFileCommand}"
                                                                        Style="{StaticResource FlatButtonStyle}">
                                                                    <StackPanel>
                                                                        <Border CornerRadius="8"
                                                                                ClipToBounds="True">
                                                                            <Grid Width="98"
                                                                                  Height="98"
                                                                                  Background="{StaticResource PanelAltBrush}">
                                                                                <Image Stretch="UniformToFill"
                                                                                       Source="{Binding ThumbnailSource}" />
                                                                            </Grid>
                                                                        </Border>
                                                                        <TextBlock Margin="0,8,0,0"
                                                                                   FontSize="12"
                                                                                   LineHeight="16"
                                                                                   MaxHeight="32"
                                                                                   Text="{Binding FileName}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Visibility="{Binding ShouldShowSpBatchDetailCards, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl ItemsSource="{Binding SpBatchResultCards}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:SpBatchResultCardViewModel}">
                                                            <Border Margin="0,0,0,8"
                                                                    Padding="12,10"
                                                                    Background="#FFFFFF"
                                                                    BorderBrush="#D9E1EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <StackPanel>
                                                                    <DockPanel>
                                                                        <TextBlock FontSize="14"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding Title}" />
                                                                        <Border DockPanel.Dock="Right"
                                                                                Padding="8,2"
                                                                                Background="#F8FAFD"
                                                                                BorderBrush="#E3EAF4"
                                                                                BorderThickness="1"
                                                                                CornerRadius="10">
                                                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                                                       Text="{Binding StatusText}" />
                                                                        </Border>
                                                                    </DockPanel>
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="{StaticResource TitleTextBrush}"
                                                                               Text="{Binding SummaryText}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               Text="{Binding DetailText}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

